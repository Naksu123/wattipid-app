{
  "expo": {
    "name": "Wattipid",
    "slug": "wattipid",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./frontend/assets/images/Wattipid-icon.png",
    "scheme": "wattipid",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wattipid.app"
    },
    "android": {
      "package": "com.wattipid.app",
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./frontend/assets/images/Wattipid-icon.png",
        "backgroundImage": "./frontend/assets/images/android-icon-background.png",
        "monochromeImage": "./frontend/assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "navigationBar": {
        "backgroundColor": "#0B0F19",
        "buttonColor": "#F9FAFB"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./frontend/assets/images/Wattipid-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./frontend/assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A",
          "dark": {
            "backgroundColor": "#0F172A"
          }
        }
      ],
      "expo-sqlite",
      "expo-font",
      "expo-image",
      "expo-sharing",
      "expo-web-browser",
      "expo-secure-store",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "notification": {
      "icon": "./frontend/assets/images/android-icon-monochrome.png",
      "color": "#10B981"
    },
    "extra": {
      "router": {
        "root": "./frontend/app"
      },
      "eas": {
        "projectId": "ffda4eb9-069b-49fa-8fb4-22459a7ad689"
      }
    }
  }
}